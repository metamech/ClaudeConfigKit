{
  "permissions": {
    "Bash": {
      "decision": "deny"
    }
  },
  "env": {
    "NODE_ENV": "development",
    INVALID_NO_QUOTES: value_no_quotes,
    "DEBUG": "true"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-bash.sh"
          }
        ]
      }
    ]
  }

